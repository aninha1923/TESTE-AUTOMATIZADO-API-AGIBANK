{
  "name": "api-dog",
  "version": "1.0.0",
  "main": "dist/app.js",
  "scripts": {
    "test:e2e": "npm run allure:clear && playwright test",
    "test:ci": "npm run test:e2e; npm run allure:generate",
    "dev": "ts-node-dev --respawn --transpile-only src/app.ts",
    "build": "tsc",
    "start": "node dist/app.js",
    "allure:clear": "node -e \"const fs = require('fs'); ['allure-results', 'allure-report'].forEach(d => { if (fs.existsSync(d)) { fs.rmSync(d, { recursive: true, force: true }); } }); fs.mkdirSync('allure-results');\"",
    "allure:generate": "allure generate allure-results --clean -o allure-report",
    "allure:open": "allure open allure-report",
    "allure:serve": "allure generate allure-results --open"
  },
  "dependencies": {
    "dotenv": "^17.2.2",
    "exceljs": "^4.4.0",
    "express": "^4.18.2",
    "pg": "^8.16.3"
  },
  "devDependencies": {
    "@eslint/js": "^9.35.0",
    "@playwright/test": "1.55.0",
    "@types/express": "^4.17.21",
    "@types/jest": "^29.5.4",
    "@types/node": "^24.3.1",
    "@types/pg": "^8.15.5",
    "allure-commandline": "^2.38.1",
    "allure-js-commons": "^3.3.3",
    "allure-mocha": "^3.4.1",
    "allure-playwright": "^3.3.3",
    "eslint": "^9.35.0",
    "eslint-config-prettier": "^9.0.0",
    "eslint-plugin-import": "^2.29.0",
    "globals": "^16.3.0",
    "jest": "^29.6.0",
    "prettier": "^3.0.0",
    "ts-jest": "^29.1.1",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.3.3",
    "typescript-eslint": "^8.42.0"
  }
}